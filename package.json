{
    "name":  "seek-talent-notification",
    "version":  "1.0.0",
    "description":  "Scrape candidates\u0027 name \u0026amp; career info into 10 columns header",
    "private":  true,
    "main":  "index.js",
    "scripts":  {
                    "dev":  "npm --prefix server run dev",
                    "dev:server":  "npm --prefix server run dev",
                    "dev:client":  "npm --prefix client run dev",
                    "start":  "npm --prefix server run start",
                    "client":  "npm --prefix client run dev",
                    "dev:all":  "concurrently -n SERVER,CLIENT -c green,blue \"npm --prefix server run dev\" \"npm --prefix client run dev\""
                },
